{
  "name": "switchboard",
  "version": "0.0.6",
  "private": true,
  "description": "A desktop app for browsing, searching, and managing CLI coding sessions",
  "author": "Doctly <support@doctly.ai>",
  "main": "./out/main/index.js",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder --config",
    "package:mac": "electron-vite build && electron-builder --mac --config",
    "package:win": "electron-vite build && electron-builder --win --config",
    "package:linux": "electron-vite build && electron-builder --linux --config",
    "release": "electron-vite build && electron-builder --publish always --config",
    "generate-icons": "node scripts/generate-icons.js && node scripts/generate-dmg-background.js"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.0.0",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@ddietr/codemirror-themes": "^1.5.2",
    "@lezer/highlight": "^1.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "codemirror": "^6.0.2",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "morphdom": "^2.7.8",
    "node-pty": "^1.1.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^0.1.96",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "electron": "^40.8.2",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "png2icons": "^2.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "electron-winstaller",
      "esbuild",
      "node-pty"
    ]
  }
}
